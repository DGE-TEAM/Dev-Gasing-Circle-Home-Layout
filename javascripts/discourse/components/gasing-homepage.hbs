<div class="gc-homepage">

  {{! ── HERO BANNER ─────────────────────────────────────────────────────────── }}
  <section class="gc-hero">
    <div class="gc-hero__content">
      <h1 class="gc-hero__greeting">
        {{theme-setting 'hero_greeting'}}{{#if this.isLoggedIn}}, {{this.displayName}}{{/if}}!
      </h1>
      <p class="gc-hero__cta-text">
        {{theme-setting 'hero_cta_text'}}
      </p>
      <div class="gc-hero__cta-actions">
        <a href={{theme-setting 'hero_cta_link'}} class="gc-btn gc-btn--primary">
          {{theme-setting 'hero_cta_button_text'}}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
        <span class="gc-hero__cta-count">
          {{this.heroRegisteredCount}} / {{theme-setting 'hero_cta_max_count'}} {{theme-setting 'hero_cta_count_label'}}
        </span>
      </div>
    </div>

    <div class="gc-hero__mascots">
      {{#if this.mascotCreativityUrl}}
        <img src={{this.mascotCreativityUrl}} alt="Maskot Creativity" class="gc-hero__mascot-img gc-hero__mascot-creativity" />
      {{/if}}
      {{#if this.mascotLogicUrl}}
        <img src={{this.mascotLogicUrl}} alt="Maskot Logic" class="gc-hero__mascot-img gc-hero__mascot-logic" />
      {{/if}}
    </div>
  </section>

  {{! ── MAIN GRID ─────────────────────────────────────────────────────────────
       Dua kolom: kiri (exclusive, komunitas, belajar) | kanan (meetup, news, minigame)
  ── }}
  <div class="gc-grid">

    {{! ── KOLOM KIRI ───────────────────────────────────────────────────────── }}
    <div class="gc-grid__left">

      {{! Eksklusif Konten }}
      {{#if this.exclusiveTopic}}
        <a href="/t/{{this.exclusiveTopic.slug}}/{{this.exclusiveTopic.id}}" class="gc-card gc-exclusive gc-exclusive--link">
          <div class="gc-exclusive__badge">Eksklusif</div>
          <h2 class="gc-card__title">{{this.exclusiveTopic.title}}</h2>
          <p class="gc-exclusive__desc">{{this.exclusiveTopic.excerpt}}</p>
          <div class="gc-exclusive__illustration">
            {{#if this.exclusiveTopic.thumbnailUrl}}
              <img src={{this.exclusiveTopic.thumbnailUrl}} alt={{this.exclusiveTopic.title}} class="gc-exclusive__img" />
            {{else if this.exclusiveTopic.imageUrl}}
              <img src={{this.exclusiveTopic.imageUrl}} alt={{this.exclusiveTopic.title}} class="gc-exclusive__img" />
            {{else}}
              <div class="gc-exclusive__img-placeholder"><span>Eksklusif Konten</span></div>
            {{/if}}
          </div>
        </a>
      {{else if this.isLoading}}
        <section class="gc-card gc-exclusive">
          <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
          <div class="gc-skeleton gc-skeleton--text gc-skeleton--meta"></div>
        </section>
      {{/if}}

      {{! Ada Apa di Komunitas Gasing? }}
      <section class="gc-card gc-komunitas">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Ada Apa di Komunitas Gasing?</h2>
          <a href="/latest" class="gc-card__more">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>

        <div class="gc-tabs">
          <button
            type="button"
            class="gc-tabs__tab {{if (eq this.activeTab 'trending') 'gc-tabs__tab--active'}}"
            {{on "click" (fn this.switchTab "trending")}}
          >Trending</button>
          <button
            type="button"
            class="gc-tabs__tab {{if (eq this.activeTab 'latest') 'gc-tabs__tab--active'}}"
            {{on "click" (fn this.switchTab "latest")}}
          >Latest</button>
        </div>

        <div class="gc-topic-list">
          {{#if this.isLoading}}
            <div class="gc-loading">
              <div class="gc-loading__spinner"></div>
              <span>Memuat...</span>
            </div>
          {{else}}
            {{#each this.visibleTopics as |topic|}}
              <GcTopicItem @topic={{topic}} @showMeta={{true}} />
            {{/each}}
          {{/if}}
        </div>
      </section>

      {{! Ayo Belajar Gasing Bersama! }}
      <section class="gc-card gc-belajar">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Ayo Belajar Gasing Bersama!</h2>
          <a href="/c/gasing-library/" class="gc-card__more">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>

        <span class="gc-belajar__label">Latest</span>

        <div class="gc-topic-list">
          {{#if this.isLoading}}
            <div class="gc-loading"><div class="gc-loading__spinner"></div></div>
          {{else}}
            {{#each this.materiTopics as |topic|}}
              <GcTopicItem @topic={{topic}} />
            {{/each}}
          {{/if}}
        </div>
      </section>
    </div>

    {{! ── KOLOM KANAN ──────────────────────────────────────────────────────── }}
    <div class="gc-grid__right">

      {{! Virtual Meet-Up }}
      <section class="gc-card gc-meetup">
        <div class="gc-card__header">
          <h2 class="gc-card__title gc-card__title--italic">Virtual Meet-Up Selanjutnya</h2>
          <a href="/c/webinar" class="gc-card__more">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>
        <div class="gc-meetup__cards">
          {{#if this.isLoading}}
            <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
          {{else if this.meetupTopics.length}}
            {{#each this.meetupTopics as |meetup|}}
              <div class="gc-meetup__event">
                {{#if meetup.thumbnailUrl}}
                  <img src={{meetup.thumbnailUrl}} alt={{meetup.title}} class="gc-meetup__event-img" />
                {{else if meetup.imageUrl}}
                  <img src={{meetup.imageUrl}} alt={{meetup.title}} class="gc-meetup__event-img" />
                {{else}}
                  <div class="gc-meetup__event-img gc-meetup__event-img--alt"></div>
                {{/if}}
                <div class="gc-meetup__event-overlay">
                  <a href="/t/{{meetup.slug}}/{{meetup.id}}" class="gc-btn gc-btn--outline gc-btn--sm">
                    Daftar
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </a>
                </div>
                <div class="gc-meetup__event-info">
                  <h3>{{meetup.title}}</h3>
                  <span>{{meetup.formattedDate}}</span>
                </div>
              </div>
            {{/each}}
          {{else}}
            <p>Belum ada acara mendatang.</p>
          {{/if}}
        </div>
      </section>

      {{! Gasing Academy News }}
      <section class="gc-card gc-news">
        <div class="gc-card__header">
          <h2 class="gc-card__title">Gasing Academy News</h2>
          <a href="/c/ga-updates" class="gc-card__more">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>
        <div class="gc-news__list">
          {{#if this.isLoading}}
            {{! Skeleton untuk 3 item berita }}
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--meta"></div>
              </div>
            </div>
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--meta"></div>
              </div>
            </div>
            <div class="gc-news__item gc-news__item--skeleton">
              <div class="gc-news__thumb gc-skeleton"></div>
              <div class="gc-news__content">
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
                <div class="gc-skeleton gc-skeleton--text gc-skeleton--meta"></div>
              </div>
            </div>
          {{else if this.newsTopics.length}}
            {{#each this.newsTopics as |news|}}
              <GcNewsItem @news={{news}} />
            {{/each}}
          {{else}}
            <div class="gc-news__empty">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2" />
              </svg>
              <p>Belum ada artikel terbaru.</p>
            </div>
          {{/if}}
        </div>
      </section>

      {{! Mini Game }}
      {{#if this.minigameTopic}}
        <section class="gc-card gc-minigame">
          <div class="gc-minigame__illustration">
            {{#if this.mascotCommunicationUrl}}
              <img src={{this.mascotCommunicationUrl}} alt="Maskot Communication" class="gc-minigame__mascot" />
            {{/if}}
          </div>
          <div class="gc-minigame__content">
            {{#if this.minigameTopic.tags.[0]}}
              <span class="gc-tag gc-tag--green">{{this.minigameTopic.tags.[0]}}</span>
            {{else}}
              <span class="gc-tag gc-tag--green">Mini Game</span>
            {{/if}}
            <h2 class="gc-minigame__title">{{this.minigameTopic.title}}</h2>
            <p class="gc-minigame__desc">{{this.minigameTopic.excerpt}}</p>
            <a href="/t/{{this.minigameTopic.slug}}/{{this.minigameTopic.id}}" class="gc-btn gc-btn--game">Ayo Main!</a>
          </div>
        </section>
      {{else if this.isLoading}}
        <section class="gc-card gc-minigame">
          <div class="gc-skeleton gc-skeleton--text gc-skeleton--title"></div>
        </section>
      {{/if}}

    </div>
  </div>
</div>
