{{!
  gc-news-item — Baris berita reusable untuk daftar news.

  Args:
    @news {Object} - News object dari mapNews()
                     Fields: id, slug, title, thumbnailUrl, imageUrl,
                             formattedDate, readTime, excerpt

  Digunakan oleh: section Gasing Academy News
}}
<a href="/t/{{@news.slug}}/{{@news.id}}" class="gc-news__item">

  {{! Thumbnail: coba thumbnailUrl → imageUrl → placeholder SVG }}
  <div class="gc-news__thumb">
    {{#if @news.thumbnailUrl}}
      <img src={{@news.thumbnailUrl}} alt={{@news.title}} class="gc-news__thumb-img" loading="lazy" />
    {{else if @news.imageUrl}}
      <img src={{@news.imageUrl}} alt={{@news.title}} class="gc-news__thumb-img" loading="lazy" />
    {{else}}
      <div class="gc-news__thumb-placeholder">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <path d="M3 9h18M9 21V9" />
        </svg>
      </div>
    {{/if}}
  </div>

  <div class="gc-news__content">
    <h3 class="gc-news__title">{{@news.title}}</h3>
    <div class="gc-news__meta">
      {{#if @news.formattedDate}}
        <span class="gc-news__date">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          {{@news.formattedDate}}
        </span>
      {{/if}}
      <span class="gc-news__readtime">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        {{@news.readTime}} menit baca
      </span>
    </div>
    {{#if @news.excerpt}}
      <p class="gc-news__excerpt">{{@news.excerpt}}</p>
    {{/if}}
  </div>

</a>
