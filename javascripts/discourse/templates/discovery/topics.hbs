{{! 
  javascripts/discourse/templates/discovery/topics.hbs
  
  This override keeps the standard Discourse topic list structure INTACT
  but wraps it in a way that the JS initializer can target.
  
  For the Gasing Academy News category, the JS layer hides the standard
  list and injects the custom Master-Detail layout into #main-outlet.
  
  For ALL other categories, this renders the default discovery template
  without any modification — ensuring full backward compatibility.
}}
{{#if this.model.category}}
  {{#if (eq this.model.category.slug "ga/updates/10")}}
    {{! 
      The gc-discovery-anchor div serves as a mount target for the JS layout.
      The standard topic-list is rendered below it so Discourse route logic
      still functions (scroll position, breadcrumbs, etc.) but it will be
      visually hidden via CSS for this category.
    }}
    <div
      id="gc-discovery-anchor"
      data-category-slug="ga/updates/10"
      data-category-id="{{this.model.category.id}}"
    >
    </div>
  {{/if}}
{{/if}}

{{! Render the original topic list — hidden via CSS for target category }}
<Discovery::Layout
  @model={{this.model}}
  @createTopic={{this.createTopic}}
  @createTopicButtonDisabled={{this.createTopicButtonDisabled}}
  @bulkSelectHelper={{this.bulkSelectHelper}}
  @canBulkSelect={{this.canBulkSelect}}
/>